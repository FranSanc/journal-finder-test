# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored. Do not commit real keys.
#
# Reminder: this app is statically hosted, so every VITE_* var here gets
# baked into the public browser bundle. Treat them as semi-public.

# Vercel AI Gateway (used by src/integrations/Core.js → InvokeLLM)
VITE_AI_GATEWAY_API_KEY=
# VITE_AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1
# VITE_AI_GATEWAY_MODEL=openai/gpt-4o-mini

# Base44 legacy (optional)
# VITE_BASE44_APP_ID=
# VITE_BASE44_APP_BASE_URL=
# VITE_BASE44_FUNCTIONS_VERSION=
