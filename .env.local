# =============================================================================
#  .env.local — local-only environment variables (gitignored, never committed)
# =============================================================================
#
#  This app is hosted as a STATIC site (no server-side code), so every var
#  here must be prefixed with `VITE_` to be readable by the client. Vite
#  inlines them into dist/ at build time.
#
#  ⚠️  SECURITY: anything in this file ends up in the public browser bundle.
#      Anyone who opens DevTools on the deployed site can read these values.
#      Only put keys here that you accept being publicly readable. Mitigate
#      by gating the app behind auth, IP restriction, or a low spending cap.
#
# -----------------------------------------------------------------------------
# Vercel AI Gateway — used by src/integrations/Core.js (InvokeLLM)
# -----------------------------------------------------------------------------

# REQUIRED. Create one at https://vercel.com/dashboard → AI Gateway → API Keys.
# Format: vck_...
VITE_AI_GATEWAY_API_KEY=vck_REPLACE_ME

# Optional. Default is the OpenAI-compatible endpoint shown below.
# VITE_AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1

# Optional. Any model the gateway supports, in `<provider>/<model>` form.
# Examples: openai/gpt-4o-mini, anthropic/claude-3-5-sonnet, xai/grok-2
# VITE_AI_GATEWAY_MODEL=openai/gpt-4o-mini

# -----------------------------------------------------------------------------
# Base44 legacy (only required if you keep using @base44/sdk)
# -----------------------------------------------------------------------------
# Leave blank if you've fully migrated off base44.
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=
VITE_BASE44_FUNCTIONS_VERSION=
